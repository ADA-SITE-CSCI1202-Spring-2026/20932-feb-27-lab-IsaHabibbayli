import java.util.Scanner;

public class MathDemo {

    public static int min(int a, int b) {
        if (a < b) {
            return a;
        } else {
            return b;
        }
    }

    public static int max(int a, int b) {
        if (a > b) {
            return a;
        } else {
            return b;
        }
    }

    public static int sum(int[] args) {
        int total = 0;
        for (int i = 0; i < args.length; i++) {
            total = total + args[i];
        }
        return total;
    }

    public static float mean(int[] args) {
        int total = sum(args);
        return (float) total / args.length;
    }

    public static int factorial(int n) {
        int result = 1;
        for (int i = 1; i <= n; i++) {
            result = result * i;
        }
        return result;
    }

    // f) Advantage of defining methods as static:
    // Static methods belong to the class, not to objects.
    // We do not need to create an object to use them.
    // We can call them directly using the class name (MathDemo.methodName).
    // It saves memory and makes the program simpler when no object data is needed.

    public static void main(String[] args) {

        int[] numbers = {2, 4, 6, 8};

        System.out.println("Min: " + min(5, 3));
        System.out.println("Max: " + max(5, 3));
        System.out.println("Sum: " + sum(numbers));
        System.out.println("Mean: " + mean(numbers));
        System.out.println("Factorial: " + factorial(5));
    }
}
